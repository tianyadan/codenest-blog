{
  "name": "codenest-static-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "content:generate": "node scripts/generate-content.mjs",
    "question-bank:migrate": "node scripts/migrate-question-bank.mjs",
    "dev": "npm run content:generate && vite --host 127.0.0.1",
    "build": "npm run content:generate && tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "npm run content:generate && vitest run",
    "test:watch": "npm run content:generate && vitest"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
